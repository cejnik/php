{% extends 'base.html.twig' %}

{% block title %}CookingBook{% endblock %}

{% block body %}
    <main class="page-shell">
        <header class="page-header">
            <div>
                <p class="eyebrow">Moje kucharka</p>
                <h1>CookingBook</h1>
            </div>
            <a class="button button-primary" href="{{ path('add_recipe') }}">Pridat recept</a>
        </header>

        <section class="recipe-grid">
            {% for recipe in recipes %}
                <article class="recipe-card">
                    <div class="recipe-card-header">
                        <div>
                            <p class="recipe-category">{{ recipe.category }}</p>
                            <h2>{{ recipe.name }}</h2>
                        </div>
                        <span class="recipe-time">{{ recipe.time }}</span>
                    </div>

                    <div class="recipe-section">
                        <h3>Suroviny</h3>
                        <p>{{ recipe.ingredients }}</p>
                    </div>

                    <div class="recipe-section">
                        <h3>Postup</h3>
                        <p>{{ recipe.instructions }}</p>
                    </div>

                    <div class="recipe-actions">
                        <a class="button button-secondary" href="{{ path('edit_recipe', { id: loop.index0 }) }}">Upravit</a>
                        <form action="{{ path('delete_recipe', { id: loop.index0 }) }}" method="post">
                            <button class="button button-danger" type="submit">Smazat</button>
                        </form>
                    </div>
                </article>
            {% endfor %}
        </section>
    </main>
{% endblock %}
