{% extends 'base.html.twig' %}

{% block title %}Hello CookingBookController!{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<div class="example-wrapper">
    {% for recipe in recipes %}
    <li><h1>{{recipe.name}}</h1></li>
    <li>{{recipe.category}}</li>
    <li>{{recipe.time}}</li>
    <li>{{recipe.ingredients}}</li>
    <li>{{recipe.instructions}}</li>
    <br>
    <form action="{{ path('delete_recipe', { id: loop.index0 }) }}" method="post">
            <button type="submit">Smaž recept</button>
    </form>
    {% endfor %}
    <br>
    <a href={{ path("add_recipe") }}>Přidat recept!</a>
</div>
{% endblock %}