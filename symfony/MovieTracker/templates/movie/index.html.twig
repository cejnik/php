{% extends 'base.html.twig' %}

{% block title %}MovieTracker{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/movie-index.css') }}">
{% endblock %}

{% block body %}
    <main class="page-shell">
        <header class="page-header">
            <div>
                <p class="eyebrow">Watchlist studio</p>
                <h1>MovieTracker</h1>
            </div>
            <a class="button button-primary" href="{{ path('new_movie') }}">Add new movie</a>
        </header>

        <nav class="filter-bar" aria-label="Movie filters">
            <a class="filter-link {{ filter == 'all' ? 'is-active' }}" href="{{ path('app_movie') }}">All</a>
            <a class="filter-link {{ filter == 'watched' ? 'is-active' }}" href="{{ path('app_movie', { filter: 'watched' }) }}">Watched</a>
            <a class="filter-link {{ filter == 'unwatched' ? 'is-active' }}" href="{{ path('app_movie', { filter: 'unwatched' }) }}">Not watched</a>
        </nav>

        <section class="movie-grid">
            {% for movie in movies %}
                <article class="movie-card">
                    <div class="movie-card-top">
                        <div>
                            <p class="movie-genre">{{ movie.genre }}</p>
                            <h2>{{ movie.title }}</h2>
                        </div>
                        <span class="movie-rating">{{ movie.rating }}/10</span>
                    </div>

                    <p class="movie-director">Directed by {{ movie.director }}</p>
                    <p class="movie-year">{{ movie.releaseYear }}</p>

                    {% if movie.watched %}
                        <form action="{{ path('toggle_movie', { id: movie.id }) }}" method="post">
                            <button class="movie-status movie-status-watched" type="submit">Watched</button>
                        </form>
                    {% else %}
                        <form action="{{ path('toggle_movie', { id: movie.id }) }}" method="post">
                            <button class="movie-status movie-status-waiting" type="submit">Not Watched</button>
                        </form>
                    {% endif %}

                    <div class="movie-actions">
                        <a class="button button-secondary" href="{{ path('edit_movie', { id: movie.id }) }}">Edit movie</a>
                        <form action="{{ path('delete_movie', { id: movie.id }) }}" method="post">
                            <button class="button button-danger" type="submit">Delete movie</button>
                        </form>
                    </div>
                </article>
            {% else %}
                <div class="empty-panel">
                    <h2>No movie yet.</h2>
                    <p>Add the first title and get the reel rolling.</p>
                    <a class="button button-primary" href="{{ path('new_movie') }}">Add new movie</a>
                </div>
            {% endfor %}
        </section>
    </main>
{% endblock %}
