{% extends 'base.html.twig' %}

{% block title %}LibraryApp{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/book-index.css') }}">
{% endblock %}

{% block body %}
    <main class="page-shell">
        <header class="page-header">
            <div>
                <p class="eyebrow">Book collection</p>
                <h1>LibraryApp</h1>
            </div>
            <a class="button button-primary" href="{{ path('book_new') }}">New book</a>
        </header>

        <section class="book-grid">
            {% for book in books %}
                <article class="book-card">
                    <div class="book-card-header">
                        <div>
                            <p class="book-genre">{{ book.genre }}</p>
                            <h2>{{ book.title }}</h2>
                        </div>
                        <span class="book-year">{{ book.year }}</span>
                    </div>

                    <p class="book-author">{{ book.author }}</p>

                    {% if book.isRead %}
                        <p class="book-status book-status-read">Book is read.</p>
                    {% else %}
                        <p class="book-status book-status-unread">Book still not read.</p>
                    {% endif %}

                    <div class="book-actions">
                        <a class="button button-secondary" href="{{ path('book_edit', { id: book.id }) }}">Edit this book</a>
                        <form action="{{ path('book_delete', { id: book.id }) }}" method="post">
                            <button class="button button-danger" type="submit">Delete this book</button>
                        </form>
                    </div>
                </article>
            {% else %}
                <div class="empty-state">
                    <h2>No books yet.</h2>
                    <p>Add your first book and start building the shelf.</p>
                    <a class="button button-primary" href="{{ path('book_new') }}">New book</a>
                </div>
            {% endfor %}
        </section>
    </main>
{% endblock %}
