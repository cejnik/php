{% extends 'base.html.twig' %}

{% block title %}Add new movie{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/movie-form.css') }}">
{% endblock %}

{% block body %}
    <main class="page-shell page-shell-narrow">
        <header class="page-header">
            <div>
                <p class="eyebrow">New reel</p>
                <h1>Add new movie</h1>
            </div>
            <a class="button button-secondary" href="{{ path('app_movie') }}">Back</a>
        </header>

        {{ form_start(form, { attr: { class: 'movie-form' } }) }}
            {{ form_widget(form) }}
            <button class="button button-primary" type="submit">Save new film</button>
        {{ form_end(form) }}
    </main>
{% endblock %}
