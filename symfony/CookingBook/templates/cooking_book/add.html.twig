{% extends 'base.html.twig' %}

{% block title %}Hello CookingBookController!{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<div class="example-wrapper">
        <form action={{ path("add_recipe")}} method="post">
            <p>Název: <input type="text" name="name"></p>
            <p>Kategorie: <input type="text" name="category"></p>
            <p>Čas: <input type="time" name="time" id=""></p>
            <p>Suroviny: <textarea name="ingredients" id=""></textarea></p>
            <p>Postup: <textarea name="instructions" id=""></textarea></p>
            <button type="submit">Přidat recept</button>
            <br>
        </form>
</div>
{% endblock %}
