{% extends 'base.html.twig' %}

{% block title %}Pridat recept{% endblock %}

{% block body %}
    <main class="page-shell page-shell-narrow">
        <header class="page-header">
            <div>
                <p class="eyebrow">Novy recept</p>
                <h1>Pridat recept</h1>
            </div>
            <a class="button button-secondary" href="{{ path('recipe_list') }}">Zpet</a>
        </header>

        <form class="recipe-form" action="{{ path('add_recipe') }}" method="post">
            <label>
                Nazev
                <input type="text" name="name">
            </label>

            <label>
                Kategorie
                <input type="text" name="category">
            </label>

            <label>
                Cas
                <input type="text" name="time" placeholder="20 min">
            </label>

            <label>
                Suroviny
                <textarea name="ingredients"></textarea>
            </label>

            <label>
                Postup
                <textarea name="instructions"></textarea>
            </label>

            <button class="button button-primary" type="submit">Pridat recept</button>
        </form>
    </main>
{% endblock %}
